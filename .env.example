# Supabase project credentials (Dashboard → Connect → Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Legacy name also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — required for `npm run db:seed` (Dashboard → Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Production (Vercel) — set the same keys in Vercel Project → Settings → Environment Variables
# Site URL + redirect: see DEPLOYMENT.md after first deploy
# ---------------------------------------------------------------------------
#   Dealer: dealer@equinox.local / Dealer123!
#   Admin:  admin@equinox.local  / Admin123!
# ---------------------------------------------------------------------------
